# ============================================================
# NeuroAgent - Environment Configuration (Example)
# ============================================================
# Copy this file to `.env` and fill in your actual API keys.
# Never commit real keys to version control.

# --- Groq API (Required for fast inference) ---
GROQ_API_KEY=

# --- Google Gemini API (Required for reasoning mode + embeddings) ---
GEMINI_API_KEY=

# --- Optional LLM providers ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Sarvam AI (Indian language translation + audio) ---
SARVAM_API_KEY=

# --- Tavily Search (Required for web search tool) ---
TAVILY_API_KEY=

# --- Pinecone (Optional long-term memory storage) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=neuroagent-memory

# --- Flask Secret Key (Change this in production!) ---
FLASK_SECRET_KEY=change-me-in-production

# --- Gmail OAuth2 (Optional) ---
GMAIL_CREDENTIALS_PATH=gmail_credentials.json
GMAIL_TOKEN_PATH=gmail_token.json

# --- App Settings ---
APP_HOST=127.0.0.1
APP_PORT=5000
DEBUG=True

